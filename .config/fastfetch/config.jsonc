{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/master/doc/json_schema.json",
  "logo": {
    "type": "none"
  },
  "modules": [
    "title",
    "kernel",
    "uptime",
    "packages",
    "terminal",
    "shell",
    "display",
    "wm",
    "cpu",
    {
      "type": "gpu",
      "hideType": "integrated"
    },
    "memory",
    "swap",
    "disk"
  ]
}
